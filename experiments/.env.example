# Copy to .env (dotenv is NOT auto-loaded; export these or use `env $(cat .env)`).
# Defaults match docker-compose.yml, so for the local stack you need nothing here.

# --- which layer + engine the server binds ---
ADAPTER=pg          # pg | mysql2 | knex | drizzle | prisma | sequelize | typeorm | objection | mikroorm
ENGINE=postgres     # postgres | mysql
PORT=3000

# --- connection pool (held constant across adapters) ---
POOL_MIN=10
POOL_MAX=10

# --- postgres ---
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=bench
PGPASSWORD=bench
PGDATABASE=bench

# --- mysql ---
MYSQLHOST=127.0.0.1
MYSQLPORT=3306
MYSQLUSER=bench
MYSQLPASSWORD=bench
MYSQLDATABASE=bench

# --- seed sizing ---
SEED_AUTHORS=1000
SEED_POSTS=20000
SEED_COMMENTS_PER_POST=10
